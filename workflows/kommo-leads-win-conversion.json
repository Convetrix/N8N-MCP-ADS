      "id": "node-get-contact",
      "name": "Ambil Kontak Lead (Kommo)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "// ========================================================\n// PARSE & NORMALIZE LEAD DATA FROM KOMMO\n// ========================================================\nconst cfg         = $('⚙️ Config — Isi Nilai di Sini').item.json;\nconst leadData    = $('Ambil Detail Lead (Kommo)').item.json;\nconst contactData = $('Ambil Kontak Lead (Kommo)').item.json;\n\nfunction getCF(cfArray, codeOrId) {\n  if (!cfArray) return null;\n  const cf = cfArray.find(f =>\n    f.field_code === codeOrId || String(f.field_id) === String(codeOrId)\n  );\n  return cf ? (cf.values[0]?.value ?? null) : null;\n}\n\nasync function sha256(str) {\n  if (!str) return null;\n  const normalized = str.trim().toLowerCase();\n  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(normalized));\n  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');\n}\n\nconst leadCF    = leadData.custom_fields_values    || [];\nconst contactCF = contactData.custom_fields_values || [];\n\nconst utm_source   = getCF(leadCF, 'utm_source')   || '';\nconst utm_medium   = getCF(leadCF, 'utm_medium')   || '';\nconst utm_campaign = getCF(leadCF, 'utm_campaign') || '';\nconst utm_content  = getCF(leadCF, 'utm_content')  || '';\nconst utm_term     = getCF(leadCF, 'utm_term')     || '';\nconst gclid        = getCF(leadCF, 'gclid')        || '';\nconst ttclid       = getCF(leadCF, 'ttclid')       || '';\nconst li_fat_id    = getCF(leadCF, 'li_fat_id')    || '';\nconst fbp          = getCF(leadCF, 'fbp')          || '';\nconst fbc          = getCF(leadCF, 'fbc')          || '';\nconst ip_address   = getCF(leadCF, 'ip_address')   || '';\nconst user_agent   = getCF(leadCF, 'user_agent')   || '';\nconst conversion_value = parseFloat(getCF(leadCF, 'conversion_value') || '0');\nconst currency     = getCF(leadCF, 'currency')     || 'IDR';\n\nconst rawEmail  = getCF(contactCF, 'EMAIL') || contactData.email || '';\nconst rawPhone  = getCF(contactCF, 'PHONE') || contactData.phone || '';\nconst rawName   = contactData.name || '';\nconst firstName = rawName.split(' ')[0] || '';\nconst lastName  = rawName.split(' ').slice(1).join(' ') || '';\nconst city      = getCF(contactCF, 'city')    || '';\nconst country   = getCF(contactCF, 'country') || 'ID';\n\nconst emailHash   = await sha256(rawEmail);\nconst phoneHash   = await sha256(rawPhone.replace(/\\D/g, ''));\nconst fnHash      = await sha256(firstName);\nconst lnHash      = await sha256(lastName);\nconst cityHash    = await sha256(city);\nconst countryHash = await sha256(country);\n\nconst src = utm_source.toLowerCase();\nconst sendMeta     = !!(src.includes('facebook') || src.includes('instagram') || src.includes('meta') || fbp || fbc);\nconst sendGoogle   = !!(src.includes('google')   || gclid);\nconst sendTikTok   = !!(src.includes('tiktok')   || ttclid);\nconst sendLinkedIn = !!(src.includes('linkedin') || li_fat_id);\n\nconst eventTime = Math.floor(Date.now() / 1000);\nconst eventId   = `leads-win-${leadData.id}-${eventTime}`;\n\nreturn {\n  cfg,\n  leadId:          leadData.id,\n  leadName:        leadData.name,\n  conversionValue: conversion_value,\n  currency,\n  eventTime,\n  eventId,\n  utm: { utm_source, utm_medium, utm_campaign, utm_content, utm_term },\n  clickIds: { gclid, ttclid, li_fat_id, fbp, fbc },\n  device: { ip_address, user_agent },\n  contact: { rawEmail, rawPhone, firstName, lastName, city, country },\n  hashed: { emailHash, phoneHash, fnHash, lnHash, cityHash, countryHash },\n  platforms: { sendMeta, sendGoogle, sendTikTok, sendLinkedIn }\n};"
      },
