      "id": "node-meta-capi",
      "name": "Meta Conversions API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1800, 80]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Parse & Normalize Lead Data').item.json;\nconst customerId = d.cfg.GOOGLE_ADS_CUSTOMER_ID.replace(/-/g, '');\nconst conversionActionId = d.cfg.GOOGLE_ADS_CONVERSION_ACTION_ID;\nconst dt = new Date(d.eventTime * 1000).toISOString();\n\nreturn {\n  ...d,\n  googlePayload: {\n    conversions: [{\n      gclid: d.clickIds.gclid || undefined,\n      conversionAction: `customers/${customerId}/conversionActions/${conversionActionId}`,\n      conversionDateTime: dt.replace('T', ' ').replace('Z', '+00:00'),\n      conversionValue: d.conversionValue || 0,\n      currencyCode: d.currency,\n      orderId: String(d.leadId),\n      userIdentifiers: [\n        { hashedEmail: d.hashed.emailHash },\n        { hashedPhoneNumber: d.hashed.phoneHash }\n      ],\n      userAgent: d.device.user_agent || ''\n    }],\n    partialFailure: true\n  },\n  googleCustomerId: customerId\n};"
      },
